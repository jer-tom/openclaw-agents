# OpenClaw VPS Environment Variables
# Copy to .env and fill in real values

PORT=62508
TZ=Asia/Kolkata
OPENCLAW_IMAGE=ghcr.io/hostinger/hvps-openclaw@sha256:<pin-a-tested-image-digest>

# Gateway
OPENCLAW_GATEWAY_TOKEN=<generate-with-openssl-rand-base64-24>
OPENCLAW_GATEWAY_PORT=18789

# LLM providers
OPENAI_API_KEY=sk-...
XAI_API_KEY=xai-...

# WhatsApp
WHATSAPP_NUMBER=*
OPENCLAW_ALLOWED_WHATSAPP_SENDERS=["+91XXXXXXXXXX"]

# Strava (from https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=<your-client-id>
STRAVA_CLIENT_SECRET=<your-client-secret>
STRAVA_ACCESS_TOKEN=<your-access-token>
STRAVA_REFRESH_TOKEN=<your-refresh-token>

# Gmail (gog CLI)
GOG_ACCOUNT=<your-gmail-address>
GOG_KEYRING_PASSWORD=<your-keyring-password>

# Blinkit geolocation
BLINKIT_LATITUDE=<your-delivery-latitude>
BLINKIT_LONGITUDE=<your-delivery-longitude>

# Only set this if Chromium cannot run with its sandbox in your container
BLINKIT_DISABLE_SANDBOX=0
